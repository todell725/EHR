# EmberHeart Reborn — configuration (copy to .env and edit)

# --- Ollama (local LLM) ---
# OpenAI-compatible base URL. In Docker on Unraid this is usually
# http://host.docker.internal:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# Model used for narrative generation (hot temperature).
# Recommend something stronger than llama3.1:8b for prose, e.g. a 70b/mixtral
# if your hardware allows.
NARRATION_MODEL=llama3.1

# Model used for cold/mechanical adjudication (can match NARRATION_MODEL).
ADJUDICATION_MODEL=llama3.1

# Local embedding model (must stay constant once the vector DB is populated).
EMBED_MODEL=nomic-embed-text

# --- temperatures ---
NARRATION_TEMPERATURE=0.9
ADJUDICATION_TEMPERATURE=0.2

# --- paths ---
# SQLite database file (state + memory + embeddings live here).
DB_PATH=./data/emberheart.db

# Corpus roots ingested as SEED lore/flavor (read-only, not authoritative state).
CORPUS_CLAUDES_EMBERHEART=/Users/todd/Projects/Dnd/Claudes-EmberHeart
CORPUS_ORIGINS=/Users/todd/Projects/emberheart-origins

# --- memory tuning ---
RAG_TOP_K=5
RAG_RELEVANCE_THRESHOLD=0.35
CONSOLIDATE_EVERY_TURNS=8

# --- world simulation ---
# Master toggle for the always-on resource economy tick. Starts OFF; flips ON
# once the player rules a domain (origins -> kingdom-building arc).
ECONOMY_TICK_ENABLED=false
ECONOMY_TICK_SECONDS=300

# --- web ---
APP_HOST=0.0.0.0
APP_PORT=8000
# Optional shared password gate for the web UI (blank = no auth).
APP_PASSWORD=
